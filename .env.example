# Alpaca Paper Trading credentials
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# Set to "true" for paper trading, "false" for live trading
ALPACA_PAPER=true

# Snowflake credentials (optional — omit to run with technical signals only)
SNOWFLAKE_ACCOUNT=your_account_identifier_here
SNOWFLAKE_USER=your_snowflake_user_here
SNOWFLAKE_PASSWORD=your_snowflake_password_here
SNOWFLAKE_DATABASE=your_snowflake_database_here
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=your_warehouse_here
SNOWFLAKE_ROLE=your_role_here

# Fully-qualified table name for SEC fundamentals data
# e.g., MY_DB.SEC_SCHEMA.FUNDAMENTALS
SEC_FILINGS_TABLE=SEC_FILINGS.PUBLIC.FUNDAMENTALS

# Snowflake Cortex model (llama3-70b, mistral-large, mixtral-8x7b)
CORTEX_MODEL=llama3-70b

# Trading settings
TOP_N_SYMBOLS=20
MAX_POSITION_SIZE=1000.00
RSI_PERIOD=14
RSI_OVERSOLD=35.0
RSI_OVERBOUGHT=65.0
LOOKBACK_DAYS=90
